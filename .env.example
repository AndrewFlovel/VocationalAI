# Supabase — https://app.supabase.com
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Gemini (solo en servidor; para desarrollo local con vercel dev usa esto en .env)
# Obtén la clave en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-gemini-api-key

# Opcional: en desarrollo con npm run dev, si la API está en Vercel, pon aquí la URL del proyecto
# Ejemplo: https://tu-proyecto.vercel.app
# VITE_API_BASE_URL=
