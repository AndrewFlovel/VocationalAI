{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { 
      "source": "/((?!api|src|node_modules|@vite|@react-refresh|@fs|@id|public|assets|favicon).*)", 
      "destination": "/index.html" 
    }
  ]
}